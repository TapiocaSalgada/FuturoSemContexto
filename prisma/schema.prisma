datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                    String             @id @default(uuid())
  name                  String
  email                 String             @unique
  password              String?
  avatarUrl             String?
  bannerUrl             String?
  bio                   String?
  role                  String             @default("user") // admin, user
  isPrivate             Boolean            @default(false)
  isTimedOut            DateTime?
  lastActiveAt          DateTime?
  lastReadAnnouncements DateTime?
  
  histories             WatchHistory[]
  favorites             Favorite[]
  favoriteFolders       FavoriteFolder[]
  comments              Comment[]
  suggestions           Suggestion[]
  settings              UserSettings?
  ratings               AnimeRating[]
  achievements          UserAchievement[]
  notifications         Notification[]     @relation("notificationRecipient")
  notificationActor     Notification[]     @relation("notificationActor")
  mobilePushTokens      MobilePushToken[]
  bugReports            BugReport[]
  
  // Follows relations
  followers             Follows[]          @relation("following")
  following             Follows[]          @relation("follower")
}

model Follows {
  followerId  String
  followingId String
  follower    User   @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User   @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Category {
  id    String @id @default(uuid())
  name  String 
  slug  String @unique
  animes Anime[]
  mangas Manga[]
}

model Anime {
  id          String   @id @default(uuid())
  title       String
  description String?
  coverImage  String?
  bannerImage String?
  status      String   @default("ongoing") // ongoing, completed
  visibility  String   @default("public")  // public, admin_only
  
  categories  Category[]
  episodes    Episode[]
  favorites   Favorite[]
  comments    Comment[]
  ratings     AnimeRating[]
  bugReports  BugReport[]
}

model Manga {
  id           String        @id @default(uuid())
  title        String
  description  String?
  coverImage   String?
  bannerImage  String?
  malId        Int?
  malUrl       String?
  status       String        @default("ongoing")
  visibility   String        @default("public") // public, admin_only
  source       String?
  sourceId     String?
  sourceUrl    String?
  language     String?
  chapters     MangaChapter[]
  categories   Category[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([title])
  @@index([malId])
}

model MangaChapter {
  id             String   @id @default(uuid())
  mangaId        String
  manga          Manga    @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  chapterNumber  Float?
  volumeNumber   Int?
  title          String?
  language       String?
  externalId     String?
  externalUrl    String?
  pages          Int?
  scanlationTeam String?
  publishedAt    DateTime?
  createdAt      DateTime @default(now())

  @@index([mangaId, chapterNumber])
  @@unique([mangaId, externalId])
}

model AnimeRating {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  animeId   String
  anime     Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)
  rating    Int      // 1-5
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, animeId])
}

model Episode {
  id            String   @id @default(uuid())
  animeId       String
  anime         Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)
  title         String
  number        Int
  season        Int      @default(1)
  videoUrl      String
  duration      String?
  sourceType    String   @default("external")
  sourceLabel   String?
  introStartSec Int?
  introEndSec   Int?
  outroStartSec Int?
  outroEndSec   Int?
  thumbnailUrl  String?
  histories     WatchHistory[]
  bugReports    BugReport[]
}

model BugReport {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  animeId     String?
  anime       Anime?   @relation(fields: [animeId], references: [id], onDelete: SetNull)
  episodeId   String?
  episode     Episode? @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  title       String
  description String
  status      String   @default("open") // open, investigating, resolved, closed
  pagePath    String?
  sourceUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt])
  @@index([animeId, createdAt])
  @@index([userId, createdAt])
}

model WatchHistory {
  id          String  @id @default(uuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episodeId   String
  episode     Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  progressSec Int     @default(0)
  watched     Boolean @default(false)
  updatedAt   DateTime @updatedAt

  @@unique([userId, episodeId])
}

model FavoriteFolder {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  isPrivate Boolean    @default(false)
  favorites Favorite[]
}

model Favorite {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  animeId          String
  anime            Anime           @relation(fields: [animeId], references: [id], onDelete: Cascade)
  favoriteFolderId String?
  folder           FavoriteFolder? @relation(fields: [favoriteFolderId], references: [id], onDelete: SetNull)

  @@unique([userId, animeId])
}

model Comment {
  id        String    @id @default(uuid())
  content   String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  animeId   String
  anime     Anime     @relation(fields: [animeId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment?  @relation("ParentChild", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("ParentChild")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Suggestion {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String   @default("pending") // pending, reviewed, accepted, rejected
  createdAt   DateTime @default(now())
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  createdAt DateTime @default(now())
}

model UserSettings {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme               String   @default("pink")
  reducedMotion       Boolean  @default(false)
  neonEffects         Boolean  @default(true)
  showHistory         Boolean  @default(true)
  autoplay            Boolean  @default(true)
  resumePlayback      Boolean  @default(true)
  playbackSpeed       String   @default("Normal")
  allowFollow         Boolean  @default(true)
  notifyAnnouncements Boolean  @default(true)
  notifyEpisodes      Boolean  @default(true)
  notifyFollowers     Boolean  @default(true)
  notifyReplies       Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("notificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?    @relation("notificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  type      String
  title     String
  body      String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
}

model MobilePushToken {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique
  platform   String?
  deviceName String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastUsedAt DateTime @default(now())

  @@index([userId, isActive])
}

// Achievements system
model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String   // references ACHIEVEMENTS constant in code
  earnedAt      DateTime @default(now())
  showOnProfile Boolean  @default(true)

  @@unique([userId, achievementId])
}
